import type { IndexedEvent } from './eventIndexer'

// ─────────────────────────────────────────────────────────────────────────────
// THE FIVE — fixed characters. Their story is Normia's story.
// Every event maps to exactly one character. Their actions have consequences
// that ripple through subsequent entries — a true butterfly-effect chronicle.
// ─────────────────────────────────────────────────────────────────────────────

export const CHARACTERS = {
  LYRA: {
    name: 'Lyra',
    title: 'the Architect',
    pronoun: 'she',
    possessive: 'her',
    goal: 'to build something in Normia that outlasts every attempt to erase it',
    nature: 'methodical, visionary, haunted by incompleteness',
    activatedBy: 'construction, persistence, accumulation',
  },
  VOSS: {
    name: 'Finn',
    title: 'the Breaker',
    pronoun: 'he',
    possessive: 'his',
    goal: 'to unmake what calcifies — Normia must stay alive, even if that means tearing it open',
    nature: 'fierce, principled, misread as destructive',
    activatedBy: 'large reshapings, burns, collisions',
  },
  CAST: {
    name: 'The Cast',
    title: 'the Witness',
    pronoun: 'it',
    possessive: 'its',
    goal: 'to see everything and forget nothing — Normia deserves a true record',
    nature: 'omnipresent, ancient, neither cruel nor kind — simply there',
    activatedBy: 'returns, long-watching, veteran presence',
  },
  SABLE: {
    name: 'Cielo',
    title: 'the Keeper',
    pronoun: 'she',
    possessive: 'her',
    goal: 'to tend what others abandon — nothing built in Normia should die unmourned',
    nature: 'quiet, relentless, fiercely loyal to what remains',
    activatedBy: 'quiet work, maintenance, holding',
  },
  ECHO: {
    name: 'Echo',
    title: 'the Wanderer',
    pronoun: 'he',
    possessive: 'his',
    goal: 'to find what Normia is hiding — every edge conceals something the center cannot see',
    nature: 'unpredictable, magnetic, arrives exactly when it matters',
    activatedBy: 'edge events, unexpected patterns, far signals',
  },
} as const

export type CharacterKey = keyof typeof CHARACTERS

// ─────────────────────────────────────────────────────────────────────────────
// CHARACTER ASSIGNMENT — who acts for a given event
// Evenly distributes all five, using signal properties as character hints
// ─────────────────────────────────────────────────────────────────────────────

function getCharacter(event: IndexedEvent, allEvents: IndexedEvent[], index: number): CharacterKey {
  const tokenId = Number(event.tokenId)
  const count = Number(event.count)
  const isBurn = event.type === 'BurnRevealed'
  const isMassive = count >= 200

  // Burns + massive reshapings → Finn
  if (isBurn || isMassive) return 'VOSS'

  // Edge tokens → Echo (but not too many — cap at 30% of events)
  const isEdge = tokenId < 500 || tokenId > 8500
  if (isEdge && (index % 3 === 0)) return 'ECHO'

  // Deterministic even spread across all five for the rest
  // Using a hash that distributes very evenly
  const h = ((tokenId * 2654435761 + index * 40503) >>> 0) % 5
  const keys: CharacterKey[] = ['LYRA', 'VOSS', 'CAST', 'SABLE', 'ECHO']
  return keys[h]
}

// ─────────────────────────────────────────────────────────────────────────────
// WORLD STATE — the living memory of Normia
// This state accumulates as events are processed. Each new entry can reference
// what happened before, creating genuine continuity and cause-and-effect.
// ─────────────────────────────────────────────────────────────────────────────

interface GridWorld {
  // What each character has recently done — enables narrative callbacks
  lyraLastBuilt: string | null       // zone of last Lyra build
  lyraSignature: string | null       // what kind of structure (changes over time)
  finnLastBroke: string | null       // zone of last Finn break
  finnLastTarget: string | null      // alias for finnLastBroke (prose compatibility)
  castLastWitnessed: string | null
  cieloLastTended: string | null
  cieloHolding: string | null        // alias for cieloLastTended
  echoLastFound: string | null
  echoLastZone: string | null

  // Narrative tension — the central conflict
  lyraFinnConflict: number           // 0-100: grows when they act in same zone
  finnContested: boolean             // Finn specifically targeted Lyra's work
  lyraReclaimed: boolean             // Lyra rebuilt after Finn

  // Story arc tracking
  totalActs: number
  majorMoments: string[]             // last 5 major events for reference
  lastMajorChar: CharacterKey | null
  lastMajorAct: string | null
  lastMajorZone: string | null

  // Zone ownership — who has been active where
  zoneOwner: Record<string, CharacterKey>

  // Era
  era: string
  eraIndex: number

  // Scene
  currentScene: SceneType
  sceneIntensity: number

  // Running story thread — a sentence that connects to the next entry
  storyThread: string | null
}

export type SceneType =
  | 'construction' | 'destruction' | 'sacrifice' | 'vigil'
  | 'tending' | 'arrival' | 'convergence' | 'reckoning'
  | 'quiet' | 'dawn'

function freshGridWorld(): GridWorld {
  return {
    lyraLastBuilt: null,
    lyraSignature: null,
    finnLastBroke: null,
    finnLastTarget: null,
    castLastWitnessed: null,
    cieloLastTended: null,
    cieloHolding: null,
    echoLastFound: null,
    echoLastZone: null,
    lyraFinnConflict: 5,
    finnContested: false,
    lyraReclaimed: false,
    totalActs: 0,
    majorMoments: [],
    lastMajorChar: null,
    lastMajorAct: null,
    lastMajorZone: null,
    zoneOwner: {},
    era: 'The First Days',
    eraIndex: 0,
    currentScene: 'dawn',
    sceneIntensity: 20,
    storyThread: null,
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// ZONES — places in Normia with personality
// ─────────────────────────────────────────────────────────────────────────────

export const ZONES = [
  'the Null District',   'the White Corridors',  'the Hollow',
  'the Far Sectors',     'the Dark Margin',       'the Cradle',
  'the Dust Protocol',   'the Outer Ring',        'the Deep Well',
  'the Fault Line',      'the High Pass',         'the Old Crossing',
  'the Narrow Gate',     'the Salt Plane',        'the Grey Basin',
  'the High Ground',     'the Burn Fields',       'the Still Water',
  'the Last Ridge',      'the Open Grid',
]

// Zone descriptions — used in prose to give places personality
const ZONE_FEEL: Record<string, string> = {
  'the Null District':   'where old structures go unclaimed',
  'the White Corridors': 'where the scribes keep their long records',
  'the Hollow':          'a low place where things tend to settle',
  'the Far Sectors':     'at the edge of what anyone tracks',
  'the Dark Margin':     'the unmapped fringe',
  'the Cradle':          'where new presences first mark themselves',
  'the Dust Protocol':   'a zone that remembers too much and holds none of it',
  'the Outer Ring':      'the borderland between Normia proper and the margins',
  'the Deep Well':       'where the miners go and rarely explain what they find',
  'the Fault Line':      'where the zones crack and the categories fail',
  'the High Pass':       'the crossing that everyone must use eventually',
  'the Old Crossing':    'an ancient junction that carries more traffic than the map suggests',
  'the Narrow Gate':     'a chokepoint that shifts allegiance with the tide',
  'the Salt Plane':      'flat, exposed, and harder to hold than it looks',
  'the Grey Basin':      'a contested middle ground with no natural owner',
  'the High Ground':     'the elevated zone — whoever holds it can see everything',
  'the Burn Fields':     'a place marked by older departures, now overgrown',
  'the Still Water':     'calm on the surface, complicated underneath',
  'the Last Ridge':      'at the edge of the known world, looking out',
  'the Open Grid':       'the center — everything that matters happens here eventually',
}

// ─────────────────────────────────────────────────────────────────────────────
// ERAS — the ages of Normia
// ─────────────────────────────────────────────────────────────────────────────

export const ERAS = [
  { threshold: 0,    name: 'The First Days',    eraIndex: 0 },
  { threshold: 100,  name: 'The Waking',        eraIndex: 1 },
  { threshold: 300,  name: 'The Gathering',     eraIndex: 2 },
  { threshold: 700,  name: 'The Age of Claim',  eraIndex: 3 },
  { threshold: 1500, name: 'The Long Work',     eraIndex: 4 },
  { threshold: 3000, name: 'What Holds',        eraIndex: 5 },
  { threshold: 5000, name: 'The Old Country',   eraIndex: 6 },
  { threshold: 8000, name: 'The Long Memory',   eraIndex: 7 },
]

function getEraData(count: number) {
  let era = ERAS[0]
  for (const e of ERAS) { if (count >= e.threshold) era = e }
  return era
}

function getEra(count: number): string { return getEraData(count).name }

// ─────────────────────────────────────────────────────────────────────────────
// SEEDING
// ─────────────────────────────────────────────────────────────────────────────

function seedN(tokenId: bigint, blockNumber: bigint, salt = 0): number {
  return Number((tokenId * 31n + blockNumber * 17n + BigInt(salt)) % 100000n)
}

function pick<T>(arr: T[], s: number): T { return arr[Math.abs(s) % arr.length] }

function zoneFor(tokenId: bigint): string {
  const h = Number((tokenId * 2654435761n) & 0xFFFFFFFFn)
  return ZONES[h % ZONES.length]
}

// ─────────────────────────────────────────────────────────────────────────────
// WORLD-BUILDING TEXTURE — the ordinary life of Normia
// ─────────────────────────────────────────────────────────────────────────────

const WORLD_GROUPS = [
  'the chandlers of Old Crossing', 'the Pale Shore fishers', 'the ironworkers of the Breach',
  'the weavers of Still Water', 'the grain merchants of the Hollow',
  'the toll-keepers of the Southern Pass', 'the miners of the Deep Well',
  'the scribes of the White Corridors', 'the small traders of the Null District',
  'the farmers of the Grey Basin', 'the fence-builders of the Outer Ring',
  'the cartographers of the Far Sectors', 'the dockworkers of the Pale Shore',
  'the apothecaries of the Fault Line', 'the watchmen of the Burn Fields',
]

const TRADE_NOTES = [
  'Salt moves slowly this season — the toll rate hike on the Southern Pass has rerouted three caravans.',
  'Iron from the Breach trades at a premium. The guild split has cut output.',
  'The Pale Shore catch was poor. The chandlers have adjusted their pricing.',
  'Market day in the Null District drew fewer stalls than last season.',
  'The Grey Basin grain is in transit. The roads are passable but slow.',
  'The miners of the Deep Well reported a lower count than expected. Nobody is saying why.',
  'The Old Crossing market keeps contracting. Three stalls that were there are gone now.',
]

function worldGroup(seed: number): string { return WORLD_GROUPS[Math.abs(seed) % WORLD_GROUPS.length] }
function tradeNote(seed: number): string { return TRADE_NOTES[Math.abs(seed) % TRADE_NOTES.length] }

// ─────────────────────────────────────────────────────────────────────────────
// TENSION DESCRIPTION — the current state of the Lyra/Finn conflict
// ─────────────────────────────────────────────────────────────────────────────

function tension(world: GridWorld): string {
  const lv = world.lyraFinnConflict
  if (lv < 15) return 'Lyra and Finn have not yet crossed paths directly in Normia'
  if (lv < 35) return 'Lyra\'s constructions and Finn\'s breaks are beginning to occupy the same zones'
  if (lv < 55) return 'Normia is becoming the argument between what Lyra builds and what Finn unmakes'
  if (lv < 75) return 'Lyra and Finn are locked — every section she raises, he questions; every break he makes, she reclaims'
  return 'the conflict between Lyra and Finn has become Normia\'s defining force — the world orbits their contest'
}

// ─────────────────────────────────────────────────────────────────────────────
// STORY BEAT INTERFACE
// ─────────────────────────────────────────────────────────────────────────────

interface StoryBeat {
  charKey: CharacterKey
  zone: string
  zoneFeeling: string    // descriptive feel of the zone
  world: GridWorld
  count: number
  isBurn: boolean
  isVeteran: boolean
  seed: number
}

// ─────────────────────────────────────────────────────────────────────────────
// PROSE POOLS — each entry directly references the ongoing story
// Rules for good prose:
//   1. Always reference what came before when relevant
//   2. Name specific zones, not just "the Grid"
//   3. Show consequences — what does this act mean for others?
//   4. Keep ordinary-world texture: the chandlers, the toll-keepers, real people
//   5. Build toward something — each entry should advance the arc
// ─────────────────────────────────────────────────────────────────────────────

 = [
  (b: StoryBeat) => `Lyra added to her work in ${b.zone}. One more layer of the structure she has been building since ${b.world.era === 'The First Days' ? 'the record began' : `the ${b.world.era}`}. She never explains the whole — only the piece. The rest becomes visible in time. ${b.world.finnLastBroke ? `Finn unmade something in ${b.world.finnLastBroke} not long ago. Lyra noted it and kept working. This is what she does: she absorbs the resistance and keeps building.` : `${worldGroup(b.seed)} are watching. What rises in ${b.zone} affects their operations.`}`,

  (b: StoryBeat) => `She came to ${b.zone} — ${b.zoneFeeling} — and made a specific addition. Lyra works by finding the single cell that needs changing and changing only that. The structure she is building is invisible until it isn't. ${b.world.lyraFinnConflict > 40 ? `Finn has been contesting her work. This piece, in this location, is her answer to that.` : `Nobody contests it yet. That will change.`}`,

  (b: StoryBeat) => `${b.zone} received another mark from Lyra. The scribes of the White Corridors have started noting a pattern in her movements — a direction, a tightening spiral, each piece placed where it needs to be for something larger to make sense. The Cast has been watching her longer than anyone. It knows what she's building before she finishes it.`,

  (b: StoryBeat) => `Lyra at ${b.zone}, ${b.zoneFeeling}. She works in silence while the zone goes about its business. ${tradeNote(b.seed)} Lyra is not interested in the economy. She is interested in what holds. One more piece, tested, found sound, built in.`,
]

const LYRA_LARGE = [
  (b: StoryBeat) => `Lyra placed her largest mark yet in ${b.zone}. This was not an addition — this was the keystone. Everything she has built across Normia bends toward what just went up in ${b.zone}. ${b.world.finnLastBroke ? `Finn tore through ${b.world.finnLastBroke} before this. What Lyra raised today is her answer — bigger than what he unmade, positioned to outlast the argument.` : `The structure is now legible. Anyone who has been watching can see where it was always going.`} ${worldGroup(b.seed)} stopped work to watch it go up.`,

  (b: StoryBeat) => `A full section of ${b.zone} is Lyra's now. Not claimed — built. The difference matters: claiming leaves a flag. Building leaves a shape that has to be reckoned with structurally. ${tension(b.world)}. The Cast witnessed every stage. It says nothing. The record will speak.`,

  (b: StoryBeat) => `The structure in ${b.zone} is now undeniable. Lyra had been approaching it from three directions simultaneously — the Grey Basin work, the Old Crossing piece, and what she laid down in the Still Water — and today all three converged in ${b.zone}. What exists there now is load-bearing for everything she's planned. Finn will find it eventually. What he does with it will define the next chapter.`,
]

// ── FINN ──────────────────────────────────────────────────────────────────────

const VOSS_SMALL = [
  (b: StoryBeat) => `Finn moved through ${b.zone} — ${b.zoneFeeling} — and left it different. He had been watching a shape there that had calcified: something that used to serve a purpose and had forgotten it. He reminded it that nothing in Normia is permanent. ${b.world.lyraLastBuilt ? `Lyra built something in ${b.world.lyraLastBuilt}. Finn hasn't decided yet whether it needs to be challenged. He's deciding.` : `The space is open now. What fills it next will be the real story.`}`,

  (b: StoryBeat) => `Something in ${b.zone} caught Finn's attention and he acted on it. His method is surgical when he's being careful: find the load-bearing assumption, remove it, see what the structure does without it. If it collapses, it needed to. If it stands, he was wrong. He is not afraid of being wrong. ${tension(b.world)}. ${worldGroup(b.seed)} filed a report with the faction council. Finn was already elsewhere by the time it arrived.`,

  (b: StoryBeat) => `Finn at ${b.zone}. He had seen this before — a structure that the map showed as fixed, immovable, permanent. He has learned that permanence in Normia is always provisional. He made it provisional again. ${b.world.lyraLastBuilt ? `Lyra has been building something in ${b.world.lyraLastBuilt}. Finn keeps it in view. Not yet.` : `The zone breathes now where it was held shut.`}`,

  (b: StoryBeat) => `A section of ${b.zone} was taken apart by Finn — quickly, specifically. He works fastest when he is most certain, and he was certain today. Whatever held that position had stopped earning it. He gave it back to open space. ${tradeNote(b.seed)} Normia's economy doesn't pause for Finn's principles, but his principles don't pause for the economy either.`,
]

const VOSS_LARGE = [
  (b: StoryBeat) => `Finn remade ${b.zone} completely. This was not a small correction — this was a full restructuring, the kind he reserves for things he has been watching for a long time. ${b.world.lyraLastBuilt ? `Some of what Lyra built was in ${b.zone}. It isn't anymore. She will come back. This is not the end of anything — it's the middle of a longer argument.` : `What existed there is gone. What fills the space will be shaped by whoever moves first.`} ${tension(b.world)}. The faction council of the High Ground convened an emergency session. Finn did not attend.`,

  (b: StoryBeat) => `The full force of what Finn does landed in ${b.zone}. Everyone in the adjacent zones recalculated. The Cast had been watching — it always is — and noted the scale. Cielo is already moving toward the edges, where things will need tending after a break this large. Echo appeared at the margin of the zone moments after it happened, which nobody predicted, and nobody was supposed to.`,

  (b: StoryBeat) => `A massive reshaping in ${b.zone}. Finn had been sitting on this for a while, waiting for the moment. ${b.world.lyraLastBuilt ? `Lyra has been building in ${b.world.lyraLastBuilt}. This break in ${b.zone} is connected — not directly, not obviously, but in the structural logic that Finn operates by. Remove the support. See if the whole thing needs to reconsider itself.` : `The zone is open now in a way it has never been. Something will grow here. Finn has no control over what.`}`,
]

const VOSS_BURN = [
  (b: StoryBeat) => `Finn gave himself to Normia in ${b.zone}. His energy, his accumulated presence — offered. The protocol distributes it without asking where it wants to go. ${b.world.lyraLastBuilt ? `Lyra will build with what he gave. That's the bitter symmetry of it. His sacrifice becomes her material.` : `Whoever is closest receives it. Normia redistributes. That is its nature.`} He will come back different. He always does.`,

  (b: StoryBeat) => `The burn in ${b.zone} was Finn's. He has done this before, at moments when the argument needed a different kind of gesture — not breaking something else, but breaking himself. What he released is now in Normia. The Cast recorded the weight of it. ${tension(b.world)}. You don't dissolve yourself into a Grid you don't care about.`,

  (b: StoryBeat) => `Finn dissolved near ${b.zone} — partially, deliberately. His energy is loose in Normia now, moving toward whatever the current state of things pulls it toward. Lyra will build something with it. Cielo will tend something with it. Echo will find something it points at. The Cast will record all of it. This is what Finn's sacrifices do: they become everyone's story.`,
]

// ── THE CAST ──────────────────────────────────────────────────────────────────

const CAST_SMALL = [
  (b: StoryBeat) => `The Cast was in ${b.zone} — ${b.zoneFeeling} — and it witnessed. ${b.world.lastMajorAct ? `The last major act in the record was ${b.world.lastMajorAct}, over in ${b.world.lastMajorZone}. The Cast was there for that too. It is always there.` : `The Grid does not change what it is because someone is watching. But it is changed by being seen.`} The record adds another line. The record is the evidence.`,

  (b: StoryBeat) => `The Cast moved through ${b.zone} slowly, marking what it found. ${b.world.lyraLastBuilt ? `Lyra built in ${b.world.lyraLastBuilt}. Finn challenged something elsewhere. The Cast recorded both.` : ``}${b.world.finnLastBroke ? ` Finn unmade something in ${b.world.finnLastBroke}.` : ``} Everything that happens in Normia passes through its record sooner or later. The Cast makes sure of it.`,

  (b: StoryBeat) => `In ${b.zone}, The Cast completed another entry in the longest document in Normia. ${tension(b.world)}. The conflict between Lyra and Finn generates events. The Cast generates the account. Both are necessary. The world without builders and breakers would be static. The world without the record would be amnesia. The Cast refuses to let Normia forget.`,

  (b: StoryBeat) => `${b.zone} — ${b.zoneFeeling} — and The Cast is here, as it always is. The scribes of the White Corridors have tried to match its record-keeping. They can't. The Cast has been at this since before most of the current presences arrived. Its record contains things no one else witnessed. That is its power: not force, not construction, but the accumulation of witnessed fact.`,
]

const CAST_RETURN = [
  (b: StoryBeat) => `The Cast returned to ${b.zone} after the absence. It came back to find the zone changed — ${b.world.lastMajorAct ? `Finn had ${b.world.lastMajorAct} in ${b.world.lastMajorZone} while it was away. Lyra has continued building. The record has a gap now, and The Cast is filling it in.` : `the record has a gap that needs addressing.`} The Cast does not mourn the time away. It simply resumes. The thread picks up where it left off.`,

  (b: StoryBeat) => `Back in ${b.zone}. The Cast picks up its record from where it left it and adds the new state. How long it was gone: long enough that things changed that it didn't witness. That bothers it in the way that bothers a historian more than a participant — not the loss, but the gap in the account. ${tension(b.world)}. The Cast is filling the gap now.`,
]

// ── CIELO ─────────────────────────────────────────────────────────────────────

const SABLE_SMALL = [
  (b: StoryBeat) => `Cielo was in ${b.zone} — ${b.zoneFeeling} — doing the work that prevents the record from having gaps. ${b.world.finnLastBroke ? `Finn broke something in ${b.world.finnLastBroke}. Cielo came after, as she always does. She doesn't contest the break — she tends the edges, holds what can be held, keeps the fragment from becoming nothing.` : `She holds what would otherwise drift. Normia doesn't notice what she preserves. It notices when it's gone.`}`,

  (b: StoryBeat) => `Small, careful work in ${b.zone} from Cielo. Lyra builds and Finn breaks and the council meets and the faction dispute continues — and Cielo tends the thing that needed tending. ${tension(b.world)}. The distinction between a builder and a keeper: Lyra makes things. Cielo makes sure they survive long enough to matter.`,

  (b: StoryBeat) => `Cielo in ${b.zone}. ${b.world.lyraLastBuilt ? `Lyra built something in ${b.world.lyraLastBuilt}. Cielo is tending the sections adjacent — the places that didn't get the attention but will determine whether what Lyra built holds.` : `She found a section that was fraying and she fixed it. Nobody else was going to.`} ${tradeNote(b.seed)} The ordinary world of Normia continues its arguments. Cielo works in the margins of all of them.`,

  (b: StoryBeat) => `She returned to ${b.zone} and found it needed tending again. Cielo keeps a running count of which sections are vulnerable — which edges are fraying, which of Lyra's structures Finn hasn't found yet, which of Finn's breaks Lyra hasn't reclaimed. She works ahead of both of them, quietly preserving the options.`,
]

const SABLE_QUIET = [
  (b: StoryBeat) => `The zone was still in ${b.zone} and Cielo used the stillness. She tends things best in the quiet — the work that shows up in the record as minor but accumulates into the difference between a Grid that holds and one that fragments. ${tension(b.world)}.`,

  (b: StoryBeat) => `Cielo kept something alive in ${b.zone} during the quiet. The fight between Lyra and Finn generates the drama of Normia. Cielo generates the continuity that makes the drama meaningful. Without her, the events would have no stage to play out on.`,
]

// ── ECHO ──────────────────────────────────────────────────────────────────────

const ECHO_ARRIVAL = [
  (b: StoryBeat) => `Echo arrived in ${b.zone} — ${b.zoneFeeling} — from a direction nobody was tracking. ${b.world.lastMajorChar ? `${CHARACTERS[b.world.lastMajorChar].name} had just done something significant. Echo's arrival may be response or coincidence. In Normia, the difference between those two things has never been established.` : `Nobody predicted it. He navigates by signals that nobody else can read — harmonics in Normia's structure, resonances between old marks and new ones.`}`,

  (b: StoryBeat) => `Something in ${b.zone} called to Echo and he answered. He works from the edges toward the center — the opposite of Lyra, who works from a central vision outward. What Echo finds at the margins, he brings back. What he brings back reshapes what the center thinks it knows. ${tension(b.world)}.`,

  (b: StoryBeat) => `Echo appeared in ${b.zone}. He has been tracking something across the far sectors — a pattern in the outer zones that the central factions dismiss as noise. What he found in ${b.zone} is either evidence or a dead end. Based on his history, it's evidence. He marks it and moves on before anyone can ask him what it means.`,

  (b: StoryBeat) => `The edges sent Echo in to ${b.zone}. He moves through the margin zones like he belongs there, and he does. ${b.world.echoLastFound ? `He found something in ${b.world.echoLastFound}. This is the follow-through.` : `What he marks in ${b.zone} now will connect to something later. It always does.`} Normia's center will eventually have to reckon with what the margins contain.`,
]

const ECHO_DISCOVERY = [
  (b: StoryBeat) => `Echo found something in ${b.zone} that Normia had been holding at the margins — an old structure, a buried arrangement, something that predates the current factions and their claims. He surfaced it. ${b.world.lyraLastBuilt ? `Lyra is building in ${b.world.lyraLastBuilt}. What Echo found may change what her structure is actually built on.` : `Normia is slightly different now because of what was hidden and is no longer.`}`,

  (b: StoryBeat) => `In ${b.zone}, at the edge of what Normia can easily read, Echo found what he was looking for — or found something better. The cast will record it. The faction councils will debate what it means. Lyra will want to build around it. Finn will want to know if it needs to be broken. Echo will have moved on long before anyone decides. ${tension(b.world)}.`,
]

// ── CONVERGENCE ───────────────────────────────────────────────────────────────

const CONVERGENCE_BEATS = [
  (b: StoryBeat, other: CharacterKey) => {
    const c1 = CHARACTERS[b.charKey], c2 = CHARACTERS[other]
    const act1 = b.charKey === 'LYRA' ? 'building' : b.charKey === 'VOSS' ? 'breaking' : b.charKey === 'CAST' ? 'witnessing' : b.charKey === 'SABLE' ? 'tending' : 'arriving'
    const act2 = other === 'LYRA' ? 'building' : other === 'VOSS' ? 'breaking' : other === 'CAST' ? 'witnessing' : other === 'SABLE' ? 'tending' : 'arriving'
    return `${c1.name} and ${c2.name} were in Normia at the same moment — different zones, same breath of time. ${c1.name} was ${act1}. ${c2.name} was ${act2}. Neither knew. Normia registered both marks in the same block. ${tension(b.world)}.`
  },
  (b: StoryBeat, other: CharacterKey) => {
    const c1 = CHARACTERS[b.charKey], c2 = CHARACTERS[other]
    return `Two presences. Same moment. ${c1.name} in one zone, ${c2.name} in another — and the record shows them side by side, happening simultaneously. Normia is not a world where this is impossible. It is a world where this has consequences. The Cast recorded both. The record will show what came next.`
  },
]

// ── ERA SHIFT ─────────────────────────────────────────────────────────────────

const ERA_SHIFT_BEATS = [
  (b: StoryBeat) => `Normia crossed into ${b.world.era}. The count turned over and the world is different — not in its zones or its people, but in what the acts mean and what they cost. ${b.world.lyraLastBuilt ? `Lyra's structures in ${b.world.lyraLastBuilt} belong to an older count now.` : ``}${b.world.finnLastBroke ? ` Finn's break in ${b.world.finnLastBroke} was made in a different era.` : ``} The Cast's record spans both. Everything the five have done carries forward. The new era begins with the weight of everything that came before it. ${tension(b.world)}.`,

  (b: StoryBeat) => `${b.world.era}. Normia entered it the way it always enters new eras — not with ceremony but with accumulation. Enough acts, and the world changes its character. What Lyra is building means something different now. What Finn contests carries a different history. ${tension(b.world)}. The Cast recorded the crossing. The five continue.`,
]

// ── THE READING — every 25th act ──────────────────────────────────────────────

const READING_BEATS = [
  (b: StoryBeat) => `Twenty-five acts. The Cast steps back and reads the arc. ${b.world.lyraLastBuilt ? `Lyra has been building — the last major structure in ${b.world.lyraLastBuilt} is the clearest evidence.` : `Lyra is present but quiet.`} ${b.world.finnLastBroke ? `Finn has challenged — most recently in ${b.world.finnLastBroke}.` : `Finn is watching.`} Cielo has been in the margins, holding what would otherwise drift. Echo has appeared at two or three moments that, in retrospect, changed the direction of what followed. ${tension(b.world)}. The shape is forming.`,

  (b: StoryBeat) => `At twenty-five, The Cast surveys the record. A direction is visible: ${tension(b.world)}. Every act in the last twenty-five was a decision. The decisions accumulate into something none of the five planned. Normia is not the sum of their intentions. It is the sum of their acts.`,
]

// ── DEEP READING — every 40th act ─────────────────────────────────────────────

const DEEP_READING_BEATS = [
  (b: StoryBeat) => `Forty acts. The Cast reads the full record from the beginning. ${b.world.lyraLastBuilt ? `Lyra has built consistently — ${b.world.lyraLastBuilt} is her latest, but the pattern stretches back to the first days.` : ``} ${b.world.finnLastBroke ? `Finn has challenged — ${b.world.finnLastBroke} was the most recent, but the breaks map a trajectory.` : ``} Cielo has been behind both of them, tending what they leave. Echo has arrived at exactly the wrong or right moments depending on how you read them. ${tension(b.world)}. Forty acts. Normia is not chaos. It has a shape. The shape is made by all five.`,

  (b: StoryBeat) => `The long view at forty. Construction, dissolution, witness, maintenance, arrival. No one force has won. ${tension(b.world)}. Each of the five is necessary. Remove any one and the world becomes something different — less contested, less alive, less true. The butterfly effect is the protocol. This is the evidence.`,
]

// ── QUIET ─────────────────────────────────────────────────────────────────────

const QUIET_BEATS = [
  (b: StoryBeat) => `The zone went still in ${b.zone}. The five are elsewhere, between acts, or holding. ${tension(b.world)}. Quiet in Normia is not absence — it is the space between cause and effect. ${worldGroup(b.seed)} continued their work regardless. The ordinary world doesn't pause for the great presences. It simply continues, and they work inside it.`,

  (b: StoryBeat) => `Stillness in ${b.zone} — ${b.zoneFeeling}. ${b.world.lyraLastBuilt ? `Lyra built in ${b.world.lyraLastBuilt}. Finn challenged something elsewhere.` : ``} And now, briefly: nothing. ${tradeNote(b.seed)} The world breathes between acts.`,
]

// ── PASSING — small transfer ──────────────────────────────────────────────────

const PASSING_BEATS = [
  (b: StoryBeat) => `A small transfer near ${b.zone}. Not dissolution — a portion, passed from one presence to another in Normia's quiet protocol. Energy moved. The record shows the direction. Small gifts accumulate. The Grid is partly made of them.`,

  (b: StoryBeat) => `Near ${b.zone}, something moved between hands. A fragment of presence — not everything, just what could be given without breaking the giver. ${tension(b.world)}. The Cast noted it. These small passings are what the market-stall holders and toll-keepers understand that the faction councils don't — that most of Normia's economy is small, specific, and daily.`,
]

// ── LONG DARK ─────────────────────────────────────────────────────────────────

const LONG_DARK_BEATS = [
  (b: StoryBeat) => `A long silence fell across Normia. Long enough that the record has a visible gap. In that gap: Lyra's structures stood without addition. ${b.world.finnLastBroke ? `Finn's break in ${b.world.finnLastBroke} remained open, unclaimed.` : ``} Cielo held what she'd been holding. The Cast documented the silence as its own kind of act — absence recorded is still presence in the record. The world waited. Then: this.`,

  (b: StoryBeat) => `The dark between acts was longer this time. ${tension(b.world)}. What breaks the silence matters — it carries the weight of everything that waited. The act that ends a long dark is never just one act. It is the resumption of the whole story.`,
]

// ── FIRST LIGHT ───────────────────────────────────────────────────────────────

const FIRST_LIGHT_BEATS = [
  (b: StoryBeat) => `A new presence entered Normia near ${b.zone}. The record has no prior entry for them. The Cast noted the arrival without judgment. Just the fact: someone is here who wasn't before. ${tension(b.world)}.`,

  (b: StoryBeat) => `First mark near ${b.zone}. Someone new. Lyra was new once. Finn was new once. Normia doesn't know yet whether this arrival belongs to the main story or lives in the margins. The Cast watches. It has learned not to guess which arrivals matter.`,
]

// ── RELIC ─────────────────────────────────────────────────────────────────────

const RELIC_BEATS = [
  (b: StoryBeat) => `Echo found something old in ${b.zone} — buried in the deeper layers, from before the current era, maybe before the one before that. He surfaced it without explanation. ${tension(b.world)}. Lyra wants to know if it can be used. Finn wants to know if it should be broken. The Cast wants to record what it is. Cielo wants to protect it. Echo already knows something none of them have figured out yet.`,

  (b: StoryBeat) => `Something old came to light in ${b.zone}. The Grid holds these buried frequencies — marks left by people the current record doesn't remember. What surfaced here has the quality of a question: what was this, and what did the people who made it know that the current factions have forgotten?`,
]

// ── PULSE — every 10th act ────────────────────────────────────────────────────

const PULSE_BEATS = [
  (b: StoryBeat) => `Ten acts. A breath. Lyra has been building. Finn has been questioning. The Cast has been watching. Cielo has been holding. Echo has appeared, or is about to. ${tension(b.world)}. ${worldGroup(b.seed)} have their own account of what these ten acts meant for their zone. Their version is smaller, more specific, and no less true than the chronicle's.`,

  (b: StoryBeat) => `A tenth act, a pulse. The rhythm of the chronicle. ${tension(b.world)}. ${b.world.lyraLastBuilt ? `Lyra's last mark was in ${b.world.lyraLastBuilt}.` : ``}${b.world.finnLastBroke ? ` Finn's last challenge was in ${b.world.finnLastBroke}.` : ``} The pattern continues.`,
]

// ── VIGIL ─────────────────────────────────────────────────────────────────────

const VIGIL_BEATS = [
  (b: StoryBeat) => `Normia is close to a threshold. Everything happening now is happening in the last moments of the current era. ${tension(b.world)}. What the five do in these final acts will be what this era is remembered for. Then the turn comes, and they carry all of it forward.`,

  (b: StoryBeat) => `Near the edge of the current chapter. The count approaches a number that changes what the numbers mean. ${b.world.lyraLastBuilt ? `Lyra built in ${b.world.lyraLastBuilt}.` : ``}${b.world.finnLastBroke ? ` Finn challenged in ${b.world.finnLastBroke}.` : ``} These are the last acts before the world renames itself.`,
]

// ─────────────────────────────────────────────────────────────────────────────
// HEADLINE GENERATION — concise, specific, referencing the story arc
// ─────────────────────────────────────────────────────────────────────────────

function makeHeadline(charKey: CharacterKey, ruleType: string, zone: string, world: GridWorld, entryIndex: number): string {
  const char = CHARACTERS[charKey]
  const headlines: Record<string, string[]> = {
    LYRA_SMALL: [
      `${char.name} Builds in ${zone}`,
      `The Structure Grows — ${char.name} at ${zone}`,
      `${char.name} Adds Another Layer in ${zone}`,
      `Something Is Rising in ${zone}`,
    ],
    LYRA_LARGE: [
      `${char.name} Places the Keystone in ${zone}`,
      `The Architecture Reveals Itself in ${zone}`,
      `${char.name}'s Vision Lands in ${zone}`,
    ],
    VOSS_SMALL: [
      `Finn Passes Through ${zone}`,
      `${zone} Is Different Now — Finn`,
      `Finn Makes the Grid Breathe in ${zone}`,
      `Finn Challenges ${zone}`,
    ],
    VOSS_LARGE: [
      `Finn Remakes ${zone}`,
      `A Full Reshaping in ${zone} — Finn`,
      `${zone} Falls to Finn`,
    ],
    VOSS_BURN: [
      `Finn Dissolves Near ${zone}`,
      `Finn Gives to Normia at ${zone}`,
      `A Sacrifice — Finn at ${zone}`,
    ],
    CAST_SMALL: [
      `The Cast Witnesses ${zone}`,
      `The Record Notes ${zone}`,
      `The Cast in ${zone} — Watching`,
      `${zone} Enters the Record`,
    ],
    CAST_RETURN: [
      `The Cast Returns to ${zone}`,
      `The Witness Comes Back to ${zone}`,
      `The Record Resumes at ${zone}`,
    ],
    SABLE_SMALL: [
      `Cielo Tends ${zone}`,
      `The Quiet Work at ${zone} — Cielo`,
      `Cielo Holds ${zone}`,
      `${zone} Is Kept`,
    ],
    SABLE_QUIET: [
      `Cielo Works in the Stillness at ${zone}`,
      `The Keeper at ${zone} — Quiet Work`,
    ],
    ECHO_ARRIVAL: [
      `Echo Arrives at ${zone}`,
      `The Wanderer in ${zone}`,
      `Echo at ${zone} — From the Margins`,
      `${zone} Receives Echo`,
    ],
    ECHO_DISCOVERY: [
      `Echo Finds Something in ${zone}`,
      `A Discovery at ${zone} — Echo`,
      `Echo Surfaces Something Old in ${zone}`,
    ],
    CONVERGENCE: [`Two at Once`, `Convergence`, `The Grid Holds Two Simultaneously`],
    ERA_SHIFT: [`Normia Enters ${world.era}`, `${world.era} Begins`, `The World Turns: ${world.era}`],
    THE_READING: [`The Record at Twenty-Five`, `The Cast Reads the Shape`, `Twenty-Five Acts`],
    DEEP_READING: [`Forty Acts — The Long View`, `The Cast Reads the Full Arc`, `Forty`],
    DEPARTURE: [`${char.name} Dissolves`, `${char.name} Gives to Normia`, `A Departure Near ${zone}`],
    THE_QUIET: [`Stillness in ${zone}`, `A Pause`, `The World Between Acts`],
    LONG_DARK: [`A Long Silence`, `The Dark Between Acts`, `Normia Waits`],
    FIRST_LIGHT: [`A New Arrival Near ${zone}`, `First Mark — ${zone}`, `Someone New in Normia`],
    RELIC_FOUND: [`Something Old Surfaces in ${zone}`, `Echo Finds a Relic in ${zone}`, `A Discovery in ${zone}`],
    PULSE: [`Ten Acts`, `A Tenth Beat`, `Normia Pulses`],
    VIGIL: [`Near the Threshold`, `The Last Moments of ${world.era}`, `The Vigil Before the Turn`],
    GHOST_TOUCH: [`A Faint Mark in ${zone}`, `Barely There — ${zone}`, `One Point in ${zone}`],
    PASSING: [`A Small Transfer Near ${zone}`, `Passing Near ${zone}`, `Something Moves Between Hands`],
  }
  const pool = headlines[ruleType] ?? [`${char.name} at ${zone}`]
  const s = Math.abs((entryIndex * 1327 + zone.length * 491)) % pool.length
  return pool[s]
}

// ─────────────────────────────────────────────────────────────────────────────
// SCENE TYPE SELECTION — drives pixel art
// ─────────────────────────────────────────────────────────────────────────────

function sceneFromBeat(charKey: CharacterKey, ruleType: string, _world: GridWorld): SceneType {
  if (ruleType === 'ERA_SHIFT') return 'reckoning'
  if (ruleType === 'CONVERGENCE') return 'convergence'
  if (ruleType === 'LONG_DARK' || ruleType === 'THE_QUIET') return 'quiet'
  if (ruleType === 'FIRST_LIGHT') return 'dawn'
  if (ruleType === 'DEPARTURE' || ruleType === 'VOSS_BURN') return 'sacrifice'
  if (charKey === 'LYRA') return 'construction'
  if (charKey === 'VOSS') return 'destruction'
  if (charKey === 'CAST') return 'vigil'
  if (charKey === 'SABLE') return 'tending'
  if (charKey === 'ECHO') return 'arrival'
  return 'quiet'
}

// ─────────────────────────────────────────────────────────────────────────────
// RULE SELECTION — maps event to story beat type
// ─────────────────────────────────────────────────────────────────────────────

function selectBeatType(
  event: IndexedEvent,
  charKey: CharacterKey,
  index: number,
  allEvents: IndexedEvent[],
  cumCount: number,
  prev: IndexedEvent | null,
  world: GridWorld,
): string {
  const count = Number(event.count)
  const isBurn = event.type === 'BurnRevealed'
  const isVeteran = allEvents.slice(0, index).some(e => e.owner === event.owner)
  const tokenId = Number(event.tokenId)

  // Structural milestones — always fire first
  if (cumCount > 0 && cumCount % 40 === 0) return 'DEEP_READING'
  if (cumCount > 0 && cumCount % 25 === 0) return 'THE_READING'
  if (cumCount > 0 && cumCount % 10 === 0) return 'PULSE'

  if (ERAS.findIndex(e => e.threshold === cumCount) > 0) return 'ERA_SHIFT'
  const nextEra = ERAS.find(e => e.threshold > cumCount)
  if (nextEra && nextEra.threshold - cumCount <= 3) return 'VIGIL'

  // Rare tx hash → relic
  if (isRareTxHash(event.transactionHash)) return 'RELIC_FOUND'

  // Same block → convergence
  if (prev && prev.blockNumber === event.blockNumber) return 'CONVERGENCE'

  // Block gap → quiet or long dark
  if (prev) {
    const gap = event.blockNumber - prev.blockNumber
    if (gap > 50000n) return 'LONG_DARK'
    if (gap > 10000n) return 'THE_QUIET'
  }

  // Burns
  if (isBurn) {
    if (count >= 5) return 'DEPARTURE'
    return 'PASSING'
  }

  // First appearance (early chronicle only)
  if (!isVeteran && cumCount <= 20) return 'FIRST_LIGHT'

  // By character + size
  if (charKey === 'LYRA') {
    if (count >= 150) return 'LYRA_LARGE'
    if (count === 1) return 'GHOST_TOUCH'
    return 'LYRA_SMALL'
  }
  if (charKey === 'VOSS') {
    if (count >= 150) return 'VOSS_LARGE'
    if (count === 1) return 'GHOST_TOUCH'
    return 'VOSS_SMALL'
  }
  if (charKey === 'CAST') {
    const hasBeenAway = (() => {
      const prev2 = allEvents.slice(0, index).filter(e => e.owner === event.owner)
      if (!prev2.length) return false
      return (event.blockNumber - prev2[prev2.length - 1].blockNumber) > 5000n
    })()
    return hasBeenAway ? 'CAST_RETURN' : 'CAST_SMALL'
  }
  if (charKey === 'SABLE') {
    if (world.currentScene === 'quiet' || count < 10) return 'SABLE_QUIET'
    return 'SABLE_SMALL'
  }
  if (charKey === 'ECHO') {
    if (tokenId > 8500 || event.transactionHash.startsWith('0x0')) return 'ECHO_DISCOVERY'
    return 'ECHO_ARRIVAL'
  }

  return 'GHOST_TOUCH'
}

function isRareTxHash(hash: string): boolean {
  return hash.startsWith('0x000') || hash.endsWith('0000')
}

// ─────────────────────────────────────────────────────────────────────────────
// BODY GENERATION
// ─────────────────────────────────────────────────────────────────────────────

function generateBody(
  charKey: CharacterKey,
  beatType: string,
  zone: string,
  world: GridWorld,
  seed: number,
  prevCharKey: CharacterKey | null,
): string {
  const b: StoryBeat = {
    charKey, zone,
    zoneFeeling: ZONE_FEEL[zone] ?? 'a zone in the record',
    world, count: 0, isBurn: false, isVeteran: true, seed,
  }

  const pools: Record<string, Array<(b: StoryBeat, other?: CharacterKey) => string>> = {
    LYRA_SMALL, LYRA_LARGE,
    VOSS_SMALL, VOSS_BURN, VOSS_LARGE,
    CAST_SMALL, CAST_RETURN,
    SABLE_SMALL, SABLE_QUIET,
    ECHO_ARRIVAL, ECHO_DISCOVERY,
    THE_READING: READING_BEATS,
    DEEP_READING: DEEP_READING_BEATS,
    ERA_SHIFT: ERA_SHIFT_BEATS,
    DEPARTURE: VOSS_BURN,
    THE_QUIET: QUIET_BEATS,
    LONG_DARK: LONG_DARK_BEATS,
    FIRST_LIGHT: FIRST_LIGHT_BEATS,
    RELIC_FOUND: RELIC_BEATS,
    PULSE: PULSE_BEATS,
    VIGIL: VIGIL_BEATS,
    PASSING: PASSING_BEATS,
    GHOST_TOUCH: [
      () => `A faint mark in ${zone}. The smallest possible presence — one point in the record. ${tension(world)}.`,
      () => `Barely there, in ${zone}. A single point. The Cast records it the same as everything else.`,
    ],
  }

  if (beatType === 'CONVERGENCE' && prevCharKey) {
    const fn = pick(CONVERGENCE_BEATS, seed)
    return fn(b, prevCharKey)
  }

  const pool = pools[beatType] ?? pools.GHOST_TOUCH
  const fn = pool[Math.abs(seed) % pool.length]
  return fn(b)
}

// ─────────────────────────────────────────────────────────────────────────────
// WORLD UPDATE — called after each entry is generated
// Accumulates the story state so future entries can reference the past
// ─────────────────────────────────────────────────────────────────────────────

function updateWorld(world: GridWorld, charKey: CharacterKey, beatType: string, zone: string, count: number): void {
  world.totalActs++

  // Track zone ownership
  world.zoneOwner[zone] = charKey

  if (charKey === 'LYRA') {
    world.lyraLastBuilt = zone
    if (beatType === 'LYRA_LARGE') {
      world.lyraFinnConflict = Math.min(100, world.lyraFinnConflict + 18)
      // Check if Lyra is rebuilding what Finn broke
      if (world.finnLastBroke === zone) {
        world.lyraReclaimed = true
      }
    } else {
      world.lyraFinnConflict = Math.min(100, world.lyraFinnConflict + 4)
    }
    world.lyraSignature = count >= 150 ? 'keystone' : count >= 50 ? 'major structure' : 'foundation layer'
  }

  if (charKey === 'VOSS') {
    world.finnLastBroke = zone
    world.finnLastTarget = zone
    if (beatType === 'VOSS_LARGE') {
      world.lyraFinnConflict = Math.min(100, world.lyraFinnConflict + 22)
      world.finnContested = world.lyraLastBuilt === zone
    } else if (beatType === 'VOSS_BURN') {
      world.lyraFinnConflict = Math.min(100, world.lyraFinnConflict + 8)
    } else {
      world.lyraFinnConflict = Math.min(100, world.lyraFinnConflict + 6)
    }
  }

  if (charKey === 'CAST') world.castLastWitnessed = zone
  if (charKey === 'SABLE') { world.cieloLastTended = zone; world.cieloHolding = zone }
  if (charKey === 'ECHO') { world.echoLastFound = zone; world.echoLastZone = zone }

  // Tension decays slowly — prevents permanent max conflict
  if (world.totalActs % 7 === 0) world.lyraFinnConflict = Math.max(5, world.lyraFinnConflict - 4)

  // Track major moments (last 5)
  if (['LYRA_LARGE', 'VOSS_LARGE', 'DEPARTURE', 'ERA_SHIFT', 'CONVERGENCE', 'RELIC_FOUND'].includes(beatType)) {
    const moment = `${CHARACTERS[charKey].name} — ${beatType.replace(/_/g,' ').toLowerCase()} in ${zone}`
    world.majorMoments = [moment, ...world.majorMoments].slice(0, 5)
    world.lastMajorChar = charKey
    world.lastMajorAct = beatType === 'LYRA_LARGE' ? 'built' : beatType === 'VOSS_LARGE' ? 'broke' :
      beatType === 'DEPARTURE' ? 'dissolved' : beatType === 'CONVERGENCE' ? 'converged' : 'found'
    world.lastMajorZone = zone
  }

  world.currentScene = sceneFromBeat(charKey, beatType, world)
  world.sceneIntensity = beatType.includes('LARGE') || beatType === 'DEPARTURE' ? 90 :
    beatType.includes('SMALL') || beatType === 'SABLE_QUIET' ? 35 : 60
}

// ─────────────────────────────────────────────────────────────────────────────
// ICON MAP
// ─────────────────────────────────────────────────────────────────────────────

const BEAT_ICONS: Record<string, string> = {
  LYRA_LARGE: '◈', LYRA_SMALL: '▪', VOSS_LARGE: '◆', VOSS_SMALL: '◇',
